{
    "name": "infinitypaul/laravel-database-filter",
    "description": "Need to filter database results with a query string? Here's a beautiful, easy to extend laravel package to keep your code super tidy.",
    "keywords": [
        "infinitypaul",
        "laravel-database-filter",
        "php filter",
        "model filter",
        "Open Source",
        "laravel",
        "github"
    ],
    "homepage": "https://github.com/infinitypaul/laravel-database-filter",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Paul Edward",
            "email": "infinitypaul@live.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.5|^11.5.50|^12.5.8"
    },
    "autoload": {
        "psr-4": {
            "Infinitypaul\\LaravelDatabaseFilter\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Infinitypaul\\LaravelDatabaseFilter\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Infinitypaul\\LaravelDatabaseFilter\\LaravelDatabaseFilterServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
